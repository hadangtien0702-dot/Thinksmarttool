# ============================================================================
# BIẾN MÔI TRƯỜNG SERVER — chép file này thành `.env` (đã gitignore) rồi dán khoá THẬT vào.
# CHỈ dùng cho tính năng admin (thêm tài khoản / đổi mật khẩu). server.js đọc từ đây.
#
# ⚠️ KHOÁ service_role LÀ BÍ MẬT TỐI CAO — bỏ qua mọi RLS. TUYỆT ĐỐI:
#    - KHÔNG commit file .env
#    - KHÔNG dán vào code phía web (config.js chỉ chứa anon key công khai)
#    - Trên Vercel: đặt ở Project → Settings → Environment Variables (KHÔNG để trong repo)
# ============================================================================

# URL dự án Supabase (đã điền sẵn — giống public/js/portal/config.js, không bí mật)
SUPABASE_URL=https://tdgunknoldhtchflopvf.supabase.co

# Khoá service_role (BÍ MẬT): Supabase → Settings → API → tab "Legacy anon, service_role API keys"
# → dòng service_role (secret) → Reveal → Copy → dán vào đây.
SUPABASE_SERVICE_ROLE_KEY=PASTE_SERVICE_ROLE_KEY_HERE
